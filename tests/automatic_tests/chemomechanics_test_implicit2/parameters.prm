set dim = 2
set global refinement = 6
set degree = 2

subsection Rectangular mesh
  set x size = 50.0
  set y size = 50.0
  #set z size = 50.0
  set x subdivisions = 1
  set y subdivisions = 1
  #set z subdivisions = 1
end

set time step = 0.01
set number steps = 100000

subsection output
  set condition = EQUAL_SPACING
  set number = 100
end

set boundary condition for C_new = Natural
set boundary condition for C_old = Natural
#set boundary condition for u, x component = Dirichlet: 0.0, Dirichlet: 0.0, Natural, Dirichlet: 0.0
#set boundary condition for u, y component = Natural, Dirichlet: 0.0, Dirichlet: 0.0, Dirichlet: 0.0
set boundary condition for u, x component = Natural
set boundary condition for u, y component = Natural
set boundary condition for S = Natural
set boundary condition for p = Natural
set Model constant radius = 5.0, DOUBLE
set Model constant concentration_initial = 1.0, DOUBLE
set Model constant C_ref = 0.1, DOUBLE
set Model constant diffusivity = 0.1, DOUBLE
set Model constant Temp = 300.0, DOUBLE
set Model constant R = 8.314, DOUBLE
set Model constant omega = 0.3, DOUBLE
set Model constant compliance = (22.5,0.3), isotropic elastic constants #MAY NEED ALTERING


subsection linear solver parameters: C_new
  set tolerance type = AbsoluteResidual
  set tolerance value = 1e-6
  set max iterations = 100000
  set preconditioner type = None
end

subsection linear solver parameters: u
  set tolerance type = AbsoluteResidual
  set tolerance value = 1e-6
  set max iterations = 100000
  set preconditioner type = GMG
end